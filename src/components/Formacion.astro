---
import { siteConfig } from "../config";
---

<section id="formacion" class="py-16 md:py-24" style={`background-color: var(--color-surface-light);`}>
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal text-center mb-14">
      <h2 class="text-2xl md:text-3xl font-bold" style={`color: var(--color-primary-dark);`}>
        Formación Académica
      </h2>
    </div>

    <!-- Academic degrees -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-14">
      {siteConfig.formacion.academica.map((item, i) => (
        <div class={`reveal stagger-${i + 1} bg-white rounded-xl border-l-4 p-6 shadow-sm`} style={`border-color: var(--color-accent);`}>
          <div class="flex items-start gap-3">
            <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center" style={`background-color: var(--color-accent); opacity: 0.15;`}>
              <svg class="w-5 h-5" style={`color: var(--color-accent);`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold" style={`color: var(--color-primary-dark);`}>
                {item.degree}
              </h3>
              <p class="text-sm font-medium mt-1" style={`color: var(--color-accent);`}>
                {item.mention}
              </p>
              <p class="text-sm mt-1" style={`color: var(--color-primary-light);`}>
                {item.school} · {item.year}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Diplomados -->
    <div class="reveal">
      <h3 class="text-xl font-bold mb-6" style={`color: var(--color-primary-dark);`}>
        Desarrollo Profesional
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {siteConfig.formacion.diplomados.map((item, i) => (
          <div class={`reveal stagger-${i + 1} bg-white rounded-lg border p-4 card-hover`} style={`border-color: var(--color-surface);`}>
            <h4 class="text-sm font-semibold" style={`color: var(--color-primary-dark);`}>
              {item.title}
            </h4>
            <p class="text-xs mt-1" style={`color: var(--color-primary-light);`}>
              {item.institution} · {item.year}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Cursos destacados -->
    <div class="reveal mt-10">
      <h3 class="text-xl font-bold mb-4" style={`color: var(--color-primary-dark);`}>
        Cursos Especializados
      </h3>
      <div class="flex flex-wrap gap-2">
        {siteConfig.formacion.cursos.map((curso) => (
          <span class="px-3 py-1.5 rounded-full text-xs font-medium border" style={`color: var(--color-primary); border-color: var(--color-primary-light); background-color: white;`}>
            {curso}
          </span>
        ))}
      </div>
    </div>

    <!-- Idiomas -->
    <div class="reveal mt-10">
      <h3 class="text-xl font-bold mb-4" style={`color: var(--color-primary-dark);`}>
        Idiomas
      </h3>
      <div class="flex flex-wrap gap-4">
        {siteConfig.idiomas.map((idioma) => (
          <div class="flex items-center gap-2 bg-white rounded-lg border px-4 py-3" style={`border-color: var(--color-surface);`}>
            <span class="font-semibold text-sm" style={`color: var(--color-primary-dark);`}>{idioma.name}</span>
            <span class="text-xs px-2 py-0.5 rounded-full" style={`color: var(--color-accent); background-color: rgba(201, 147, 62, 0.1);`}>
              {idioma.level}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
