---
import { siteConfig } from "../config";
---

<section id="reconocimientos" class="py-16 md:py-20" style={`background-color: var(--color-primary-dark);`}>
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-white">
        Reconocimientos
      </h2>
      <p class="mt-3 text-base max-w-lg mx-auto" style={`color: var(--color-primary-light);`}>
        Excelencia reconocida por las instituciones donde he servido.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {siteConfig.reconocimientos.map((item, i) => (
        <div class={`reveal stagger-${i + 1} rounded-xl border p-6`} style={`background-color: rgba(26, 58, 92, 0.5); border-color: rgba(59, 107, 150, 0.3);`}>
          <div class="flex items-start gap-4">
            <div class="shrink-0">
              <span class="star-glow text-2xl" style={`color: var(--color-accent);`}>&#9733;</span>
            </div>
            <div>
              <h3 class="text-base font-bold text-white">
                {item.title}
              </h3>
              <p class="text-sm mt-1" style={`color: var(--color-accent);`}>
                {item.institution} · {item.year}
              </p>
              <p class="text-sm mt-2 leading-relaxed" style={`color: rgba(255, 255, 255, 0.7);`}>
                {item.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
