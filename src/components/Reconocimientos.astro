---
import { siteConfig } from "../config";
---

<section id="reconocimientos" class="py-20 md:py-28 relative overflow-hidden" style={`background: linear-gradient(135deg, var(--color-primary-dark) 0%, #060E1A 100%);`}>
  <!-- Decorative glow -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-[0.05]" style={`background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);`}></div>

  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <div class="reveal text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] mb-3" style={`color: var(--color-accent);`}>
        Excelencia Reconocida
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Reconocimientos
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {siteConfig.reconocimientos.map((item, i) => (
        <div class={`reveal stagger-${i + 1} group rounded-xl border p-7 transition-all duration-300 card-hover`} style={`background: rgba(26, 58, 92, 0.3); border-color: rgba(59, 107, 150, 0.2);`}>
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style={`background: linear-gradient(135deg, rgba(201, 147, 62, 0.2), rgba(201, 147, 62, 0.05));`}>
              <span class="star-glow text-xl" style={`color: var(--color-accent);`}>&#9733;</span>
            </div>
            <div>
              <h3 class="text-base font-bold text-white group-hover:text-white transition-colors">
                {item.title}
              </h3>
              <p class="text-sm mt-1.5 font-medium" style={`color: var(--color-accent);`}>
                {item.institution}
              </p>
              <p class="text-xs mt-0.5" style={`color: rgba(255,255,255,0.4);`}>
                {item.year}
              </p>
              <p class="text-sm mt-3 leading-relaxed" style={`color: rgba(255, 255, 255, 0.6);`}>
                {item.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
