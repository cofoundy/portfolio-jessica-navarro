---
import { siteConfig } from "../config";
---

<section id="cifras" class="py-16 md:py-20" style={`background-color: var(--color-surface);`}>
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="reveal text-center text-2xl md:text-3xl font-bold mb-12" style={`color: var(--color-primary-dark);`}>
      Cifras de Impacto
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-8">
      {siteConfig.stats.map((stat, i) => (
        <div class={`reveal stagger-${i + 1} text-center p-6 rounded-xl bg-white border shadow-sm card-hover`} style={`border-color: ${i === 0 ? 'var(--color-accent)' : 'var(--color-surface)'};`}>
          <div class="text-3xl md:text-4xl font-bold" style={`color: ${stat.value === 'CPC' || stat.value === 'Maestría' ? 'var(--color-accent)' : 'var(--color-primary-dark)'}; font-family: 'DM Serif Display', serif;`}>
            {stat.value}
          </div>
          <div class="mt-2 text-sm font-medium" style={`color: var(--color-primary-light);`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
