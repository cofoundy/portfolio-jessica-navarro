---
import { siteConfig } from "../config";
---

<footer id="contacto" class="relative py-20 md:py-28 overflow-hidden" style={`background-color: var(--color-surface);`}>
  <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
    <div class="reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] mb-3" style={`color: var(--color-accent);`}>
        Contacto
      </p>
      <h2 class="text-3xl md:text-4xl font-bold" style={`color: var(--color-primary-dark);`}>
        Conversemos
      </h2>
      <p class="text-base mt-4 max-w-md mx-auto" style={`color: var(--color-primary-light);`}>
        Disponible para nuevas oportunidades en auditoría gubernamental y control institucional.
      </p>
    </div>

    <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-sm font-semibold transition-all duration-300 hover:shadow-[0_0_30px_rgba(201,147,62,0.3)] hover:scale-[1.02]"
        style={`background-color: var(--color-accent); color: var(--color-primary-dark);`}
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {siteConfig.social.email}
      </a>
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-sm font-semibold border-2 transition-all duration-300 hover:shadow-lg"
        style={`color: var(--color-primary-dark); border-color: var(--color-primary-dark);`}
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="mt-16 pt-6 border-t text-center" style={`border-color: rgba(11, 29, 58, 0.1);`}>
    <p class="text-xs" style={`color: var(--color-primary-light);`}>
      &copy; {new Date().getFullYear()} Jessica Paola Navarro Jesús
    </p>
  </div>
</footer>
