---
import { siteConfig } from "../config";
---

<section id="hero" class="relative overflow-hidden min-h-[90vh] flex items-center" style={`background: linear-gradient(135deg, #060E1A 0%, var(--color-primary-dark) 40%, var(--color-primary) 100%);`}>
  <!-- Decorative grid pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23C9933E&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M0 0h1v1H0V0zm20 0h1v1h-1V0zM0 20h1v1H0v-1zm20 20h1v1h-1v-1z&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>

  <!-- Radial glow behind photo -->
  <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full opacity-[0.08]" style={`background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);`}></div>

  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 relative z-10 w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
      <!-- Photo with decorative frame -->
      <div class="hero-photo shrink-0">
        <div class="relative">
          <!-- Decorative gold corner brackets -->
          <div class="absolute -top-3 -left-3 w-10 h-10 border-t-2 border-l-2 rounded-tl-lg" style={`border-color: var(--color-accent);`}></div>
          <div class="absolute -bottom-3 -right-3 w-10 h-10 border-b-2 border-r-2 rounded-br-lg" style={`border-color: var(--color-accent);`}></div>

          <div class="w-52 h-52 md:w-64 md:h-64 rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10">
            <img
              src="/profile.jpg"
              alt={siteConfig.name}
              class="w-full h-full object-cover object-top"
              loading="eager"
            />
          </div>

          <!-- Floating credential badge -->
          <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 hero-credential">
            <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide shadow-lg" style={`background-color: var(--color-accent); color: var(--color-primary-dark);`}>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              {siteConfig.hero.credential}
            </span>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="text-center md:text-left">
        <p class="hero-subtitle text-sm font-semibold uppercase tracking-[0.2em] mb-4" style={`color: var(--color-accent);`}>
          {siteConfig.hero.tagline}
        </p>

        <h1 class="hero-title text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] text-white">
          Jessica Paola<br />
          <span style={`color: var(--color-primary-light);`}>Navarro Jesús</span>
        </h1>

        <div class="hero-bio mt-6 flex flex-wrap items-center justify-center md:justify-start gap-3">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border" style={`color: rgba(255,255,255,0.8); border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05);`}>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
            Maestría en Auditoría
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border" style={`color: rgba(255,255,255,0.8); border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05);`}>
            Contadora Pública Colegiada
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border" style={`color: rgba(255,255,255,0.8); border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05);`}>
            18+ Años OCI
          </span>
        </div>

        <p class="hero-bio mt-6 text-base leading-relaxed max-w-lg" style={`color: rgba(255, 255, 255, 0.6);`}>
          {siteConfig.hero.bio}
        </p>

        <!-- Social -->
        <div class="hero-social mt-8 flex items-center justify-center md:justify-start gap-4">
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all duration-300 hover:shadow-[0_0_30px_rgba(201,147,62,0.3)] hover:scale-[1.02]"
            style={`background-color: var(--color-accent); color: var(--color-primary-dark);`}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Contactar
          </a>
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium text-white border transition-all duration-300 hover:bg-white/10 hover:border-white/30"
            style={`border-color: rgba(255, 255, 255, 0.2);`}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Stats trust bar integrated in hero -->
    <div class="hero-social mt-16 grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-10 pt-12 border-t" style={`border-color: rgba(255, 255, 255, 0.1);`}>
      {siteConfig.stats.slice(0, 3).map((stat) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold" style={`color: var(--color-accent); font-family: 'DM Serif Display', serif;`}>
            {stat.value}
          </div>
          <div class="mt-1 text-xs uppercase tracking-widest" style={`color: rgba(255,255,255,0.5);`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom shimmer -->
  <div class="absolute bottom-0 left-0 right-0 bar-shimmer h-1"></div>
</section>
