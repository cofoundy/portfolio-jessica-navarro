---
import { siteConfig } from "../config";

const iconPaths: Record<string, string> = {
  search: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  alert: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
  eye: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
  file: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
};
---

<section id="especializacion" class="py-16 md:py-20" style={`background-color: var(--color-surface);`}>
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold" style={`color: var(--color-primary-dark);`}>
        Especialización
      </h2>
      <p class="mt-3 text-base max-w-xl mx-auto" style={`color: var(--color-primary-light);`}>
        Tipos de control gubernamental que domina a nivel de supervisión y jefatura de comisión.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {siteConfig.especializacion.map((item, i) => (
        <div class={`reveal stagger-${i + 1} bg-white rounded-xl border p-6 card-hover`} style={`border-color: var(--color-surface);`}>
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: var(--color-primary-dark);`}>
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon] || iconPaths.file} />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold" style={`color: var(--color-primary-dark);`}>
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed" style={`color: var(--color-primary);`}>
                {item.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
