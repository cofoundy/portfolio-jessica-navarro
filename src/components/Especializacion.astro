---
import { siteConfig } from "../config";

const iconPaths: Record<string, string> = {
  search: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  alert: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
  eye: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
  file: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
};
---

<section id="especializacion" class="py-20 md:py-28 relative" style={`background: linear-gradient(180deg, #060E1A 0%, var(--color-primary-dark) 100%);`}>
  <!-- Subtle pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23C9933E&quot;%3E%3Cpath d=&quot;M0 0h1v1H0V0zm20 0h1v1h-1V0zM0 20h1v1H0v-1zm20 20h1v1h-1v-1z&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>

  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <div class="reveal text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] mb-3" style={`color: var(--color-accent);`}>
        Competencias Core
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Especialización
      </h2>
      <p class="mt-4 text-base max-w-xl mx-auto" style={`color: rgba(255,255,255,0.5);`}>
        Tipos de control gubernamental que domina a nivel de supervisión y jefatura de comisión.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {siteConfig.especializacion.map((item, i) => (
        <div class={`reveal stagger-${i + 1} group relative rounded-xl border p-7 md:p-8 transition-all duration-300 hover:border-opacity-50 card-hover`} style={`background: rgba(26, 58, 92, 0.3); border-color: rgba(59, 107, 150, 0.2);`}>
          <!-- Number -->
          <div class="absolute top-6 right-6 text-5xl font-bold opacity-[0.08] text-white" style="font-family: 'DM Serif Display', serif;">
            {String(i + 1).padStart(2, '0')}
          </div>

          <div class="flex items-start gap-5">
            <div class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center transition-all duration-300 group-hover:scale-110" style={`background: linear-gradient(135deg, var(--color-accent), #D4A853); box-shadow: 0 8px 24px rgba(201, 147, 62, 0.2);`}>
              <svg class="w-6 h-6" style="color: #0B1D3A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon] || iconPaths.file} />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed" style={`color: rgba(255,255,255,0.6);`}>
                {item.description}
              </p>
            </div>
          </div>

          <!-- Hover gold line at bottom -->
          <div class="absolute bottom-0 left-6 right-6 h-0.5 rounded-full scale-x-0 group-hover:scale-x-100 transition-transform duration-500" style={`background-color: var(--color-accent);`}></div>
        </div>
      ))}
    </div>
  </div>
</section>
