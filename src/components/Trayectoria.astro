---
import { siteConfig } from "../config";

const sectorColors: Record<string, string> = {
  Electoral: "#7C3AED",
  Agrario: "#059669",
  Ambiental: "#0891B2",
  "Producción": "#EA580C",
  Municipal: "#2563EB",
  "Educación": "#7C3AED",
  Social: "#DB2777",
  Regional: "#CA8A04",
};

const sectorIcons: Record<string, string> = {
  Electoral: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
  Agrario: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064",
  Ambiental: "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9",
  "Producción": "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
  Municipal: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  "Educación": "M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
  Social: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  Regional: "M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9",
};
---

<section id="trayectoria" class="py-16 md:py-24" style={`background-color: var(--color-surface-light);`}>
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal text-center mb-14">
      <h2 class="text-2xl md:text-3xl font-bold" style={`color: var(--color-primary-dark);`}>
        Trayectoria Institucional
      </h2>
      <p class="mt-3 text-base max-w-2xl mx-auto" style={`color: var(--color-primary-light);`}>
        Más de 18 años de servicio en Órganos de Control Institucional del Estado peruano, auditando entidades de alcance nacional, regional y local.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line (mobile & desktop) -->
      <div class="absolute left-6 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5" style={`background-color: var(--color-primary-light); opacity: 0.3;`}></div>

      {siteConfig.trayectoria.map((item, i) => {
        const isLeft = i % 2 === 0;
        const sectorColor = sectorColors[item.sector] || "var(--color-primary)";
        const iconPath = sectorIcons[item.sector] || sectorIcons["Municipal"];

        return (
          <div class={`reveal ${isLeft ? 'reveal-left' : 'reveal-right'} stagger-${(i % 3) + 1} relative flex items-start gap-4 md:gap-0 mb-10 md:mb-12`}>
            <!-- Timeline dot -->
            <div class="absolute left-6 md:left-1/2 -translate-x-1/2 z-10 w-4 h-4 rounded-full border-[3px] bg-white mt-6" style={`border-color: ${sectorColor};`}></div>

            <!-- Content - alternating sides on desktop -->
            <div class={`ml-14 md:ml-0 ${isLeft ? 'md:mr-[calc(50%+2rem)] md:text-right' : 'md:ml-[calc(50%+2rem)]'} w-full`}>
              <div class="bg-white rounded-xl border p-5 md:p-6 shadow-sm card-hover" style={`border-color: var(--color-surface);`}>
                <!-- Header -->
                <div class={`flex items-start gap-3 ${isLeft ? 'md:flex-row-reverse md:text-right' : ''}`}>
                  <div class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style={`background-color: ${sectorColor}15;`}>
                    <svg class="w-5 h-5" style={`color: ${sectorColor};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap" style={isLeft ? 'justify-content: flex-end;' : ''}>
                      <h3 class="text-lg font-bold" style={`color: var(--color-primary-dark);`}>
                        {item.institution}
                      </h3>
                      <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style={`background-color: ${sectorColor};`}>
                        {item.sector}
                      </span>
                    </div>
                    <p class="text-sm mt-0.5" style={`color: var(--color-primary-light);`}>
                      {item.fullName}
                    </p>
                  </div>
                </div>

                <!-- Role & Period -->
                <div class="mt-3 flex items-center gap-2 text-sm flex-wrap" style={isLeft ? 'justify-content: flex-end;' : ''}>
                  <span class="font-semibold" style={`color: var(--color-accent);`}>{item.role}</span>
                  <span style={`color: var(--color-primary-light);`}>·</span>
                  <span style={`color: var(--color-primary-light);`}>{item.period}</span>
                </div>

                <!-- Highlights -->
                <ul class={`mt-3 space-y-1.5 ${isLeft ? 'md:text-right' : ''}`}>
                  {item.highlights.map((h) => (
                    <li class="text-sm flex items-start gap-2" style={`color: var(--color-primary); ${isLeft ? 'justify-content: flex-end;' : ''}`}>
                      {!isLeft && <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style={`background-color: var(--color-accent);`}></span>}
                      <span>{h}</span>
                      {isLeft && <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style={`background-color: var(--color-accent);`}></span>}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
